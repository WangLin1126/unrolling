    "import torch\n",
    "wy = torch.fft.fftfreq(8, device='cpu')* 2 * torch.pi\n",
    "wx = torch.fft.rfftfreq(8, device='cpu') * 2 * torch.pi\n",
    "WY, WX = torch.meshgrid(wy, wx, indexing=\"ij\")"
   ]
